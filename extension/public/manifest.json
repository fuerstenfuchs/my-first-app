{
  "manifest_version": 3,
  "name": "PromptDB",
  "description": "Finde und kopiere deine KI-Prompts direkt im Browser.",
  "version": "1.1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "clipboardWrite",
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.vercel.app/*",
    "https://*.supabase.co/*"
  ]
}
