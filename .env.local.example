# Supabase — get these from supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Allowlist — only this email can log in (single-user app)
ALLOWED_EMAIL=your_email@example.com

# OpenAI — für semantische Suche (PROJ-14); get from platform.openai.com/api-keys
# Server-only (kein NEXT_PUBLIC_ Prefix — Key wird nie an den Browser gesendet)
OPENAI_API_KEY=sk-proj-...
